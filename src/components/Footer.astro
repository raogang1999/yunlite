---
/** Footer */
const year = new Date().getFullYear();
---

<footer class="py-10 border-t border-cream-200">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-400">
      <div class="flex items-center gap-2">
        <span class="text-warm-gradient font-serif font-semibold"
          data-i18n data-zh="云砺" data-en="Yunlite">云砺</span>
        <span
          data-i18n
          data-zh={`© ${year} 龙岩市新罗区云砺信息咨询服务部`}
          data-en={`© ${year} Yunlite Studio`}
        >© {year} 龙岩市新罗区云砺信息咨询服务部</span>
      </div>
      <div class="flex items-center gap-4">
        <a
          href="https://beian.miit.gov.cn/"
          target="_blank"
          rel="noopener"
          class="hover:text-gray-600 transition-colors"
        >
          闽ICP备XXXXXXXX号
        </a>
      </div>
    </div>
  </div>
</footer>