---
/** 固定顶部导航栏 — 滚动后出现毛玻璃效果 */
const navLinks = [
  { href: '#philosophy', labelZh: '理念', labelEn: 'Philosophy' },
  { href: '#products', labelZh: '产品', labelEn: 'Products' },
  { href: '#contact', labelZh: '联系', labelEn: 'Contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2.5 group">
      <span
        class="text-warm-gradient font-serif text-xl font-bold tracking-wide"
        data-i18n
        data-zh="云砺"
        data-en="Yunlite"
      >
        云砺
      </span>
      <span
        class="text-xs tracking-[0.2em] text-gray-400 font-light uppercase hidden sm:inline"
        data-i18n
        data-zh="Yunlite Studio"
        data-en="Yunlite Studio"
      >
        Yunlite Studio
      </span>
    </a>
    <!-- Links -->
    <div class="flex items-center gap-6 text-sm">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-gray-500 hover:text-warm-600 transition-colors duration-200"
          data-i18n
          data-zh={link.labelZh}
          data-en={link.labelEn}
        >
          {link.labelZh}
        </a>
      ))}
      <button
        type="button"
        class="lang-toggle"
        data-lang-toggle
        data-lang="zh"
        aria-label="Switch to English"
      >
        <span class="lang-zh">中文</span>
        <span class="lang-divider">/</span>
        <span class="lang-en">EN</span>
      </button>
    </div>
  </div>
</nav>
